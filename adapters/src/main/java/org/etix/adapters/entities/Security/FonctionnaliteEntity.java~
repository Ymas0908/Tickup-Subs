package com.itcentrex.adapter.entities.Security;

import com.itcentrex.domain.models.Security.Fonctionnalite;
import jakarta.persistence.*;
import lombok.*;

import java.io.Serializable;
import java.time.LocalDateTime;


@Data
@ToString
@NoArgsConstructor
@AllArgsConstructor
@Entity
@Builder
@Table(name = "fonctionnalite")
public class FonctionnaliteEntity implements Serializable {

    private static final long serialVersionUID = -7932089617544590363L;

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    protected Integer id;

    @Column(name = "created_date")
    protected LocalDateTime createdAt;

    @Column(name = "deleted_date")
    protected LocalDateTime deletedAt;

    @Column(name = "statut_actif", nullable = false)
    private Boolean statutActif;

    @Column(name = "libelle", length = 200, nullable = false)
    private String libelle;

    @Column(name = "page_url", length = 250, nullable = false)
    private String pageUrl;

    @Column(name = "description", length = 250, nullable = true)
    private String description;

    @Column(name = "code", length = 25, nullable = false)
    private String code;

    public static FonctionnaliteEntity toEntity(Fonctionnalite fonctionnalite) {
        return new FonctionnaliteEntityBuilder()
                .id(fonctionnalite.getId())
                .createdAt(fonctionnalite.getCreatedAt())
                .deletedAt(fonctionnalite.getDeletedAt())
                .statutActif(fonctionnalite.getStatutActif())
                .libelle(fonctionnalite.getLibelle())
                .pageUrl(fonctionnalite.getPageUrl())
                .description(fonctionnalite.getDescription())
                .code(fonctionnalite.getCode())
                .build();
    }

    public Fonctionnalite toDomain() {
        return new Fonctionnalite.Builder()
                .id(id)
                .createdAt(createdAt)
                .deletedAt(deletedAt)
                .statutActif(statutActif)
                .libelle(libelle)
                .pageUrl(pageUrl)
                .description(description)
                .code(code)
                .build();
    }
}
