package com.itcentrex.adapter.ports.driven.repositories;


import com.itcentrex.adapter.entities.Security.FonctionnaliteEntity;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Optional;
import java.util.Set;

@Repository
public interface FonctionnaliteRepository extends JpaRepository<FonctionnaliteEntity, Integer> {

    @Override
    @Query("SELECT DISTINCT f FROM FonctionnaliteEntity f ORDER BY f.libelle ASC")
    List<FonctionnaliteEntity> findAll();

    Optional<FonctionnaliteEntity> findByCode(String code);

    Optional<FonctionnaliteEntity> findByLibelleIgnoreCase(String libelle);

    @Query("SELECT f FROM FonctionnaliteEntity f  WHERE f.createdAt between :dateA AND :dateB")
    List<FonctionnaliteEntity> findByCreatedAtBetween(@Param("dateA") LocalDateTime dateA, @Param("dateB") LocalDateTime dateB);

    List<FonctionnaliteEntity> findAllByCodeOrLibelleIgnoreCase(String code, String libelle);

    @Query("SELECT DISTINCT p.fonctionnalites FROM  ProfilAccesEntity p WHERE p.id IN :profilsId ")
    List<FonctionnaliteEntity> findFonctionnalitesByProfilIdsIn(@Param("profilsId") Set<Integer> profilsId);
}
